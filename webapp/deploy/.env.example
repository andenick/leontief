# .env.example — Leontief website environment variables
# Copy to .env and adjust before running docker compose.
#
# No API keys required to SERVE the site — all data (BEA I-O tables) is static/local.
# site_data/ is pre-built on the dev machine before `docker build`.
# (Rebuilding source data from BEA requires a free BEA_API_KEY — see the root .env.example.)

# Public hostname served by this instance (used in site meta + CORS if added later)
LEONTIEF_HOST=leontief.nickanderson.us

# Gunicorn worker count (default 2; increase if the box has more cores)
WORKERS=2

# Internal app port (exposed only to caddy/nginx — NOT to the host)
PORT=8080
