# Leontief — environment variables
# Copy to .env and fill in. Never commit a real .env (it is gitignored).

# --- Required to REBUILD the source data from the BEA API ---
# Free key — register at https://apps.bea.gov/API/signup/
BEA_API_KEY=

# --- Optional ---
# Root directory the Technical/ analysis scripts read and write under.
# Defaults to the current working directory (".") if unset.
DATA_ROOT=

# Public hostname for the webapp (also settable in webapp/deploy/.env.example).
LEONTIEF_HOST=leontief.nickanderson.us
